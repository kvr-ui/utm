# ── Zoho / Bigin credentials (server-side only; never exposed to the browser) ──
ZOHO_CLIENT_ID=1000.xxxxxxxxxxxxxxxxxxxx
ZOHO_CLIENT_SECRET=your_client_secret
ZOHO_REFRESH_TOKEN=1000.xxxxxxxx.xxxxxxxx
ZOHO_REGION=in

# ── Server ──
PORT=8080
COUNSELING_ALLOWED_ORIGINS=http://localhost:8080,https://focasedu.com,https://www.focasedu.com

# Built website to serve (single-port). Absolute path to the website's dist/ folder.
FRONTEND_DIST=/absolute/path/to/FOCAS-Edu-Website-main/dist

# ── External leads API (full student details + UTM params; not stored in Bigin) ──
LEADS_API_URL=https://your-leads-api.example.com/api/leads/web

# ── Rate limit ──
COUNSELING_RATE_MAX=5
COUNSELING_RATE_WINDOW_MS=600000
COUNSELING_TRUST_PROXY=true
